#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SPEC_FILE="${SPEC_FILE:-$ROOT_DIR/spec.md}"

if [[ ! -f "$SPEC_FILE" ]]; then
  echo "spec file not found: $SPEC_FILE" >&2
  exit 1
fi

PROMPT_FILE="$(mktemp)"
trap 'rm -f "$PROMPT_FILE"' EXIT

cat >"$PROMPT_FILE" <<'EOF'
Implement the project according to the following specification.
Work in the current repository, make code changes directly, and run validation commands.
EOF

printf "\n--- BEGIN SPEC (%s) ---\n\n" "$SPEC_FILE" >>"$PROMPT_FILE"
cat "$SPEC_FILE" >>"$PROMPT_FILE"
printf "\n\n--- END SPEC ---\n" >>"$PROMPT_FILE"

cd "$ROOT_DIR"
agent exec --cd "$ROOT_DIR" - <"$PROMPT_FILE" "$@"
